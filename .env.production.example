# Copy to .env.production on the Mac mini server. Do not commit real secrets.
# Used only so CI can validate docker-compose.prod.yml without real secrets.
APP_ENV_FILE=.env.production.example
POSTGRES_DB=heritage_rag
POSTGRES_USER=heritage
POSTGRES_PASSWORD=change-me-long-random-password
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_PORT=5432
API_BIND_HOST=127.0.0.1
API_PORT=8000

DATABASE_URL=postgresql+psycopg://heritage:change-me-long-random-password@db:5432/heritage_rag
OPENAI_API_KEY=
LLM_PROVIDER=ollama
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
EMBEDDING_MODEL=BAAI/bge-m3
KHS_API_BASE=http://www.khs.go.kr
