# LLM provider 선택: "gemini" (기본, 테스트) 또는 "openai" (본 구현)
LLM_PROVIDER=gemini

# Gemini (테스트용)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (본 구현용)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# 질의 재작성 등 보조 작업용 저렴한 모델 (멀티턴 비용 절감)
GEMINI_CONDENSE_MODEL=gemini-2.5-flash-lite
OPENAI_CONDENSE_MODEL=gpt-4.1-mini

# 임베딩 (RAG). 기본은 LLM_PROVIDER 를 따름.
# gemini -> text-embedding-004 (768차원), openai -> text-embedding-3-small (1536차원)
EMBED_PROVIDER=gemini
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_EMBED_DIM=768
OPENAI_EMBED_MODEL=text-embedding-3-small

# pgvector (docker-compose 의 postgres)
PGHOST=localhost
PGPORT=5432
PGUSER=heritage
PGPASSWORD=heritage
PGDATABASE=heritage
